    <string name="settings_accessibility_capture_disclosure">RayoAI only takes screenshots when you press the shortcut or accessibility button. The image is sent to Gemini to generate a description and is saved in your history.</string>
    <string name="settings_accessibility_capture_setup_title">Enable RayoAI accessibility</string>
    <string name="settings_accessibility_capture_setup_message">This feature requires enabling the RayoAI accessibility service. On Android 11 or higher, some devices may ask you to allow restricted settings before the service can be enabled. If it appears blocked, open the RayoAI app info screen in Settings, open More options, and allow restricted settings. The name and location of this option can vary by device and brand. Then return to Accessibility and enable RayoAI quick capture.</string>
    <string name="accessibility_service_label">RayoAI quick capture</string>
    <string name="accessibility_service_description">Allows blind and low-vision people to capture the screen or focused element with a volume shortcut or the accessibility button, send it to RayoAI, and get a description.</string>
